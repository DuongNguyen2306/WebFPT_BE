NODE_ENV=development
PORT=3000
# Local: mongodb://localhost:27017/telecom_landing
# Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/telecom_landing?appName=FPT
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/telecom_landing?appName=FPT

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Swagger: URL deploy hiển thị trong dropdown server (không có /api/v1)
# API_PUBLIC_URL=https://api.your-domain.com/api/v1
# SWAGGER_EXPORT=true

# Chỉ dùng khi chạy seed (tạo admin lần đầu). Đăng nhập API KHÔNG đọc các biến này.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMeAdmin123!
# ADMIN_FORCE_RESET_PASSWORD=true  # bật khi muốn seed ghi đè passwordHash trong DB

# Cloudinary — upload ảnh gói (admin)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=telecom-packages
# Ảnh hero khi Cloudinary lỗi hoặc không gửi file (POST /admin/packages/with-image)
PACKAGE_FALLBACK_HERO_IMAGE_URL=https://res.cloudinary.com/dgntcyf41/image/upload/v1716644000/sample.jpg
CLOUDINARY_TIMEOUT_MS=300000
HTTP_REQUEST_TIMEOUT_MS=360000

# Discord — thông báo đơn đăng ký mới từ website (tùy chọn)
# Tạo webhook: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
