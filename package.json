{
  "name": "telecom-landing-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "seed": "ts-node -r tsconfig-paths/register src/seed/run-seed.ts",
    "seed:admin": "ts-node -r tsconfig-paths/register src/seed/reset-admin.ts",
    "db:setup": "ts-node -r tsconfig-paths/register src/seed/setup-database.ts",
    "db:purge-sample": "ts-node -r tsconfig-paths/register src/seed/purge-sample-data.ts",
    "db:fix-admin-collision": "ts-node -r tsconfig-paths/register src/seed/fix-customer-admin-collision.ts",
    "db:admins-only": "ts-node -r tsconfig-paths/register src/seed/migrate-admins-only.ts",
    "hash:password": "ts-node -r tsconfig-paths/register src/seed/hash-password.ts",
    "db:consolidate": "ts-node -r tsconfig-paths/register src/seed/consolidate-to-telecom-landing.ts",
    "seed:packages": "ts-node -r tsconfig-paths/register src/seed/import-packages-json.ts",
    "seed:packages:generate": "ts-node -r tsconfig-paths/register src/seed/generate-packages-seed.ts",
    "seed:navigation": "ts-node -r tsconfig-paths/register src/seed/import-menus-json.ts",
    "seed:package-quiz": "ts-node -r tsconfig-paths/register src/seed/import-package-quiz-json.ts",
    "db:drop-sample-mflix": "ts-node -r tsconfig-paths/register src/seed/drop-sample-mflix.ts",
    "db:up": "docker compose up mongo -d",
    "db:down": "docker compose stop mongo",
    "test:cloudinary": "ts-node -r tsconfig-paths/register src/seed/test-cloudinary.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.4.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.3",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
